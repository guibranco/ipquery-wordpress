{
    "name": "guibranco/ipquery",
    "description": "WordPress plugin for IP geolocation and risk analysis via the IpQuery API",
    "type": "wordpress-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Guilherme Branco Stracini",
            "email": "opensource@guilhermebranco.com.br",
            "homepage": "https://github.com/guibranco"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "brain/monkey": "^2.6",
        "squizlabs/php_codesniffer": "^3.9",
        "wp-coding-standards/wpcs": "^3.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "lint:fix": "phpcbf"
    }
}
